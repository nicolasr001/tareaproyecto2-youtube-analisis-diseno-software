{
  "openapi": "3.0.4",
  "info": {
    "title": "BC2 - Catalogo Editorial y Derechos",
    "description": "Responsabilidad central: definir que contenido existe publicamente, como se presenta y bajo que reglas puede mostrarse (legal, territorial, etaria, moderacion).\n\nAqui el 'video' es un CatalogItem (item de catalogo editorial), NUNCA un archivo. Un CatalogItem puede existir sin estar publicado. La visibilidad depende de reglas editoriales y legales, no de infraestructura de streaming.\n\nAlcance (Si): canales, metadata editorial, publicacion, playlists, derechos, restricciones.\nAlcance (No): transcoding, ranking de recomendaciones, comentarios, facturacion.\n\nEste contexto actua como Open Host Service: publica eventos estandar que Descubrimiento, Monetizacion y Publicidad consumen sin integracion a medida.\n\nEventos que EMITE: ItemPublished, ItemUnpublished, ItemUpdated, RestrictionApplied, RestrictionLifted, RightsClaimCreated, RightsClaimResolved.\nEventos que CONSUME: AssetReadyForPublishing (desde BC1 Publicacion).\n\nRequisitos funcionales cubiertos: RF-C1 (canales), RF-C2 (creacion editorial), RF-C3 (publicacion y visibilidad), RF-C4 (playlists), RF-C5 (derechos), RF-C6 (politicas y restricciones).",
    "version": "1.0.0",
    "contact": { "name": "Equipo BC2 - Catalogo", "email": "bc2-catalogo@proyecto-youtube.uoh.cl" }
  },
  "servers": [
    { "url": "https://api.youtube-ddd.local/catalogo/v1", "description": "Servidor del Bounded Context Catalogo Editorial y Derechos" }
  ],
  "tags": [
    { "name": "channels", "description": "RF-C1: Gestion de canales" },
    { "name": "catalog-items", "description": "RF-C2: Creacion y edicion editorial" },
    { "name": "publication", "description": "RF-C3: Publicacion y visibilidad" },
    { "name": "playlists", "description": "RF-C4: Playlists" },
    { "name": "rights", "description": "RF-C5: Derechos y reclamaciones" },
    { "name": "policies", "description": "RF-C6: Politicas y restricciones" }
  ],
  "paths": {
    "/channels": {
      "post": {
        "tags": ["channels"],
        "summary": "Crear un canal.",
        "description": "RF-C1: El sistema debe permitir crear un canal asociado a un creador.",
        "operationId": "createChannel",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateChannelRequest" },
              "example": { "creatorId": "usr-7f2a1c", "name": "Canal de Tutoriales DDD" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Canal creado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Channel" },
                "example": { "channelId": "chn-55ee10", "creatorId": "usr-7f2a1c", "name": "Canal de Tutoriales DDD", "description": "", "imageUrl": null }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/channels/{channelId}": {
      "get": {
        "tags": ["channels"],
        "summary": "Consultar informacion publica del canal.",
        "description": "RF-C1: El sistema debe permitir consultar la informacion publica del canal (nombre, descripcion, imagen).",
        "operationId": "getChannel",
        "parameters": [{ "$ref": "#/components/parameters/ChannelIdParam" }],
        "responses": {
          "200": { "description": "Datos del canal.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["channels"],
        "summary": "Actualizar informacion publica del canal.",
        "description": "RF-C1: El sistema debe permitir actualizar la informacion publica del canal.",
        "operationId": "updateChannel",
        "parameters": [{ "$ref": "#/components/parameters/ChannelIdParam" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateChannelRequest" } } }
        },
        "responses": {
          "200": { "description": "Canal actualizado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/channels/{channelId}/items": {
      "get": {
        "tags": ["channels"],
        "summary": "Listar contenido publicado de un canal.",
        "description": "RF-C1: El sistema debe permitir listar el contenido publicado de un canal.",
        "operationId": "listChannelItems",
        "parameters": [
          { "$ref": "#/components/parameters/ChannelIdParam" },
          { "$ref": "#/components/parameters/PageParam" },
          { "$ref": "#/components/parameters/PageSizeParam" }
        ],
        "responses": {
          "200": { "description": "Lista paginada de items publicados.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItemListResponse" } } } }
        }
      }
    },
    "/catalog/items": {
      "post": {
        "tags": ["catalog-items"],
        "summary": "Vincular un asset tecnico con metadata editorial.",
        "description": "RF-C2: El sistema debe permitir vincular un VideoAsset (del contexto Publicacion) con metadata editorial (titulo, descripcion, tags, categoria, miniatura), guardandolo como BORRADOR.",
        "operationId": "createCatalogItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCatalogItemRequest" },
              "example": {
                "assetId": "ast-9d12ef",
                "channelId": "chn-55ee10",
                "title": "Introduccion a Domain-Driven Design",
                "description": "En este video explicamos los conceptos basicos de DDD.",
                "tags": ["ddd", "arquitectura", "software"],
                "category": "EDUCATION",
                "thumbnailUrl": "https://cdn.youtube-ddd.local/thumbs/ast-9d12ef.jpg"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "CatalogItem creado en estado DRAFT.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CatalogItem" },
                "example": {
                  "itemId": "itm-30bf77",
                  "assetId": "ast-9d12ef",
                  "channelId": "chn-55ee10",
                  "title": "Introduccion a Domain-Driven Design",
                  "status": "DRAFT",
                  "visibility": { "isPublished": false, "minAge": 0, "blockedCountries": [] }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/catalog/items/{itemId}": {
      "get": {
        "tags": ["catalog-items"],
        "summary": "Consultar un item del catalogo.",
        "operationId": "getCatalogItem",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "responses": {
          "200": { "description": "Item del catalogo.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["catalog-items"],
        "summary": "Editar metadata de contenido existente.",
        "description": "RF-C2: El sistema debe permitir editar metadata de contenido existente.",
        "operationId": "updateCatalogItem",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateCatalogItemRequest" } } }
        },
        "responses": {
          "200": { "description": "Item actualizado. Emite evento ItemUpdated si estaba publicado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/catalog/items/{itemId}/publish": {
      "post": {
        "tags": ["publication"],
        "summary": "Publicar un contenido.",
        "description": "RF-C3: El sistema debe permitir publicar un contenido, haciendolo disponible segun reglas definidas. Emite evento ItemPublished consumido por Descubrimiento, Monetizacion y Publicidad.",
        "operationId": "publishItem",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "responses": {
          "200": {
            "description": "Item publicado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CatalogItem" },
                "example": { "itemId": "itm-30bf77", "status": "PUBLISHED", "visibility": { "isPublished": true, "minAge": 0, "blockedCountries": [] } }
              }
            }
          },
          "409": { "description": "El item no puede publicarse (ej. restringido por reclamo de derechos)." }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/catalog/items/{itemId}/unpublish": {
      "post": {
        "tags": ["publication"],
        "summary": "Despublicar u ocultar contenido.",
        "description": "RF-C3: El sistema debe permitir despublicar u ocultar contenido. Emite evento ItemUnpublished.",
        "operationId": "unpublishItem",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "responses": {
          "200": { "description": "Item despublicado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } } } }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/catalog/items/{itemId}/visibility": {
      "get": {
        "tags": ["publication"],
        "summary": "Consultar si un contenido es visible para un usuario.",
        "description": "RF-C3: Consulta sincrona usada por otros contextos (ej. Publicacion antes de servir el stream) para validar visibilidad segun pais, edad y estado de moderacion. Patron Conformist: los demas contextos se conforman a esta respuesta.",
        "operationId": "checkVisibility",
        "parameters": [
          { "$ref": "#/components/parameters/ItemIdParam" },
          { "name": "country", "in": "query", "schema": { "type": "string", "example": "CL" } },
          { "name": "viewerAge", "in": "query", "schema": { "type": "integer", "example": 25 } }
        ],
        "responses": {
          "200": {
            "description": "Resultado de la validacion de visibilidad.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VisibilityCheckResponse" },
                "example": { "itemId": "itm-30bf77", "isVisible": true, "reason": null }
              }
            }
          }
        }
      }
    },
    "/playlists": {
      "post": {
        "tags": ["playlists"],
        "summary": "Crear una coleccion ordenada de contenidos.",
        "description": "RF-C4: El sistema debe permitir crear colecciones ordenadas de contenidos.",
        "operationId": "createPlaylist",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePlaylistRequest" },
              "example": { "channelId": "chn-55ee10", "title": "Serie DDD Completa" }
            }
          }
        },
        "responses": {
          "201": { "description": "Playlist creada.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Playlist" } } } }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/playlists/{playlistId}/items": {
      "post": {
        "tags": ["playlists"],
        "summary": "Agregar un item a la playlist.",
        "description": "RF-C4: El sistema debe permitir agregar, quitar y reordenar items en una coleccion.",
        "operationId": "addPlaylistItem",
        "parameters": [{ "$ref": "#/components/parameters/PlaylistIdParam" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddPlaylistItemRequest" }, "example": { "itemId": "itm-30bf77", "position": 1 } } }
        },
        "responses": {
          "200": { "description": "Item agregado a la playlist.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Playlist" } } } }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      },
      "get": {
        "tags": ["playlists"],
        "summary": "Consultar una playlist con su orden.",
        "description": "RF-C4: El sistema debe permitir consultar una playlist con su orden.",
        "operationId": "getPlaylistItems",
        "parameters": [{ "$ref": "#/components/parameters/PlaylistIdParam" }],
        "responses": {
          "200": { "description": "Items ordenados de la playlist.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Playlist" } } } }
        }
      }
    },
    "/catalog/items/{itemId}/rights-claims": {
      "post": {
        "tags": ["rights"],
        "summary": "Registrar una reclamacion de derechos.",
        "description": "RF-C5: El sistema debe permitir registrar reclamaciones de derechos sobre un contenido. Emite evento RightsClaimCreated.",
        "operationId": "createRightsClaim",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRightsClaimRequest" },
              "example": { "claimantName": "Productora XYZ", "reason": "Uso no autorizado de musica registrada" }
            }
          }
        },
        "responses": {
          "201": { "description": "Reclamacion registrada.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RightsClaim" } } } }
        }
      }
    },
    "/rights-claims/{claimId}/resolve": {
      "post": {
        "tags": ["rights"],
        "summary": "Resolver una reclamacion.",
        "description": "RF-C5: El sistema debe permitir resolver una reclamacion (aceptar, disputar, retirar). Si se acepta, puede restringir el contenido. Emite evento RightsClaimResolved.",
        "operationId": "resolveRightsClaim",
        "parameters": [{ "name": "claimId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResolveRightsClaimRequest" },
              "example": { "resolution": "ACCEPTED", "restrictItem": true }
            }
          }
        },
        "responses": {
          "200": { "description": "Reclamacion resuelta.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RightsClaim" } } } }
        }
      }
    },
    "/catalog/items/{itemId}/restrictions": {
      "post": {
        "tags": ["policies"],
        "summary": "Aplicar una restriccion de contenido.",
        "description": "RF-C6: El sistema debe permitir aplicar restricciones (edad minima, bloqueo geografico, limitacion de monetizacion). Emite evento RestrictionApplied.",
        "operationId": "applyRestriction",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ApplyRestrictionRequest" },
              "example": { "type": "AGE_RESTRICTION", "value": "18" }
            }
          }
        },
        "responses": {
          "200": { "description": "Restriccion aplicada.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } } } }
        },
        "security": [{ "bearerAuth": ["system"] }]
      },
      "get": {
        "tags": ["policies"],
        "summary": "Consultar historial de estado de politica.",
        "description": "RF-C6: El sistema debe mantener el historial de estado de politica de cada contenido y permitir consultarlo.",
        "operationId": "getRestrictionHistory",
        "parameters": [{ "$ref": "#/components/parameters/ItemIdParam" }],
        "responses": {
          "200": {
            "description": "Historial de restricciones.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/RestrictionHistoryEntry" } } } }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ChannelIdParam": { "name": "channelId", "in": "path", "required": true, "schema": { "type": "string" } },
      "ItemIdParam": { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Identificador del CatalogItem (NO confundir con assetId de Publicacion)." },
      "PlaylistIdParam": { "name": "playlistId", "in": "path", "required": true, "schema": { "type": "string" } },
      "PageParam": { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
      "PageSizeParam": { "name": "pageSize", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 } }
    },
    "schemas": {
      "CreateChannelRequest": {
        "type": "object",
        "required": ["creatorId", "name"],
        "properties": { "creatorId": { "type": "string" }, "name": { "type": "string" } }
      },
      "UpdateChannelRequest": {
        "type": "object",
        "properties": { "name": { "type": "string" }, "description": { "type": "string" }, "imageUrl": { "type": "string" } }
      },
      "Channel": {
        "type": "object",
        "description": "Entidad editorial. NO es la misma entidad que CommunityProfile en Audiencia ni AdvertiserAccount en Publicidad.",
        "properties": {
          "channelId": { "type": "string" },
          "creatorId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "imageUrl": { "type": "string", "nullable": true }
        }
      },
      "CreateCatalogItemRequest": {
        "type": "object",
        "required": ["assetId", "channelId", "title"],
        "properties": {
          "assetId": { "type": "string", "description": "Referencia al VideoAsset del BC1 Publicacion (RNF-2: ID compartido, modelo NO compartido)." },
          "channelId": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "category": { "type": "string" },
          "thumbnailUrl": { "type": "string" }
        }
      },
      "UpdateCatalogItemRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CatalogItem": {
        "type": "object",
        "description": "Aggregate Root de este Bounded Context. Representa el video como producto editorial publico, distinto del VideoAsset tecnico.",
        "properties": {
          "itemId": { "type": "string" },
          "assetId": { "type": "string" },
          "channelId": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "UNPUBLISHED"] },
          "visibility": { "$ref": "#/components/schemas/VisibilityPolicy" }
        }
      },
      "VisibilityPolicy": {
        "type": "object",
        "description": "Value Object embebido en CatalogItem (composicion).",
        "properties": {
          "isPublished": { "type": "boolean" },
          "minAge": { "type": "integer" },
          "blockedCountries": { "type": "array", "items": { "type": "string" } }
        }
      },
      "VisibilityCheckResponse": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string" },
          "isVisible": { "type": "boolean" },
          "reason": { "type": "string", "nullable": true, "example": "AGE_RESTRICTED" }
        }
      },
      "CatalogItemListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CatalogItem" } },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalItems": { "type": "integer" }
        }
      },
      "CreatePlaylistRequest": {
        "type": "object",
        "required": ["channelId", "title"],
        "properties": { "channelId": { "type": "string" }, "title": { "type": "string" } }
      },
      "AddPlaylistItemRequest": {
        "type": "object",
        "required": ["itemId"],
        "properties": { "itemId": { "type": "string" }, "position": { "type": "integer" } }
      },
      "Playlist": {
        "type": "object",
        "properties": {
          "playlistId": { "type": "string" },
          "channelId": { "type": "string" },
          "title": { "type": "string" },
          "orderedItemIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CreateRightsClaimRequest": {
        "type": "object",
        "required": ["claimantName", "reason"],
        "properties": { "claimantName": { "type": "string" }, "reason": { "type": "string" } }
      },
      "ResolveRightsClaimRequest": {
        "type": "object",
        "required": ["resolution"],
        "properties": {
          "resolution": { "type": "string", "enum": ["ACCEPTED", "DISPUTED", "WITHDRAWN"] },
          "restrictItem": { "type": "boolean", "default": false }
        }
      },
      "RightsClaim": {
        "type": "object",
        "description": "Entidad del agregado CatalogItem (composicion: 1 CatalogItem -- 0..* RightsClaim).",
        "properties": {
          "claimId": { "type": "string" },
          "itemId": { "type": "string" },
          "claimantName": { "type": "string" },
          "status": { "type": "string", "enum": ["OPEN", "ACCEPTED", "DISPUTED", "WITHDRAWN"] }
        }
      },
      "ApplyRestrictionRequest": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": { "type": "string", "enum": ["AGE_RESTRICTION", "GEO_BLOCK", "MONETIZATION_LIMIT"] },
          "value": { "type": "string" }
        }
      },
      "RestrictionHistoryEntry": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "value": { "type": "string" },
          "appliedAt": { "type": "string", "format": "date-time" },
          "liftedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": { "code": { "type": "string" }, "message": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" } }
      }
    },
    "responses": {
      "BadRequest": { "description": "Solicitud invalida.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "NotFound": { "description": "Recurso no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
    },
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
