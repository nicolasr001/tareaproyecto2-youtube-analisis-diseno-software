    <!-- ═══════════════ DDD DESIGN NOTE ═══════════════ -->
    <mxCell id="ddnote" value="&lt;b&gt;Nota de diseño DDD — BC4 Audiencia&lt;/b&gt;&lt;br&gt;• CommunityMember: modelo canónico del usuario en BC4 (distinto a Viewer en BC3, Creator en BC2, Advertiser en BC6)&lt;br&gt;• Subscription = relación social (seguir un canal), NO suscripción de pago (eso vive en BC5 Monetización)&lt;br&gt;• BC2CatalogClient es un Anti-Corruption Layer: BC4 guarda solo channelId, jamás duplica metadata editorial (RNF-2)&lt;br&gt;• EventBus desacopla: UserSubscribed es consumido por BC4 (notificaciones) y opcionalmente por BC3 (Descubrimiento)" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="60" y="530" width="810" height="90" as="geometry"/>
