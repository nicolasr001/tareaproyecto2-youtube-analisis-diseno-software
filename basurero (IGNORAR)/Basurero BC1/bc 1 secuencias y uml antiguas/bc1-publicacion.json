{
  "openapi": "3.0.4",
  "info": {
    "title": "BC1 - Publicación y Distribución de Contenido",
    "description": "Responsabilidad central: gestionar el ciclo de vida tecnico del video: subida, procesamiento, almacenamiento, reproduccion y transmision en vivo.\n\nEste contexto conoce al video como VideoAsset (archivo/stream), nunca como producto editorial. No decide si el contenido es visible al publico, no gestiona metadata visible (titulo, descripcion, tags) y no conoce comentarios, recomendaciones ni pagos. Esa responsabilidad pertenece a otros Bounded Contexts.\n\nAlcance (Si): upload, transcoding, streaming, sesiones de playback, live.\nAlcance (No): titulo del video, comentarios, recomendaciones, pagos, campanas publicitarias.\n\nEventos que este contexto EMITE: VideoUploaded, ProcessingCompleted, ProcessingFailed, AssetReadyForPublishing, PlaybackSessionCompleted, LiveStreamStarted, LiveStreamEnded.\n\nRequisitos funcionales cubiertos: RF-P1 (gestion de subida), RF-P2 (procesamiento tecnico), RF-P3 (reproduccion), RF-P4 (transmision en vivo), RF-P5 (consulta de assets tecnicos).",
    "version": "1.0.0",
    "contact": {
      "name": "Equipo BC1 - Publicacion",
      "email": "bc1-publicacion@proyecto-youtube.uoh.cl"
    }
  },
  "servers": [
    {
      "url": "https://api.youtube-ddd.local/publicacion/v1",
      "description": "Servidor del Bounded Context Publicacion y Distribucion"
    }
  ],
  "tags": [
    {
      "name": "uploads",
      "description": "RF-P1: Gestion de subida de archivos de video"
    },
    {
      "name": "processing",
      "description": "RF-P2: Procesamiento tecnico (transcoding) del video"
    },
    {
      "name": "playback",
      "description": "RF-P3: Reproduccion y sesiones de playback"
    },
    {
      "name": "live",
      "description": "RF-P4: Transmision en vivo"
    },
    {
      "name": "assets",
      "description": "RF-P5: Consulta de assets tecnicos del creador"
    }
  ],
  "paths": {
    "/assets/uploads/initiate": {
      "post": {
        "tags": ["uploads"],
        "summary": "Iniciar una subida de video.",
        "description": "RF-P1: El sistema debe permitir que un creador inicie una subida de video, completa o por partes.",
        "operationId": "initiateUpload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InitiateUploadRequest" },
              "example": {
                "creatorId": "usr-7f2a1c",
                "fileName": "tutorial-ddd-parte1.mp4",
                "fileSizeBytes": 524288000,
                "mode": "MULTIPART"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subida iniciada correctamente.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAsset" },
                "example": {
                  "assetId": "ast-9d12ef",
                  "creatorId": "usr-7f2a1c",
                  "uploadStatus": "PENDING",
                  "processingStatus": "NOT_STARTED",
                  "createdAt": "2026-06-20T10:15:00Z"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/uploads/{uploadId}/parts": {
      "put": {
        "tags": ["uploads"],
        "summary": "Subir una parte del archivo.",
        "description": "RF-P1: El sistema debe permitir subir el archivo de forma completa o por partes, e informar el progreso.",
        "operationId": "uploadPart",
        "parameters": [
          { "$ref": "#/components/parameters/UploadIdParam" },
          {
            "name": "partNumber",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Numero de la parte del archivo siendo subida."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parte recibida. Devuelve el progreso acumulado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadProgress" },
                "example": { "uploadId": "upl-aa11bb", "partNumber": 3, "percentCompleted": 42.5 }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/uploads/{uploadId}/complete": {
      "post": {
        "tags": ["uploads"],
        "summary": "Finalizar una subida.",
        "description": "RF-P1 / RF-P2: Valida que la subida finalizo correctamente y dispara automaticamente el procesamiento (transcoding).",
        "operationId": "completeUpload",
        "parameters": [{ "$ref": "#/components/parameters/UploadIdParam" }],
        "responses": {
          "200": {
            "description": "Subida finalizada y procesamiento iniciado automaticamente.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAsset" },
                "example": {
                  "assetId": "ast-9d12ef",
                  "creatorId": "usr-7f2a1c",
                  "uploadStatus": "COMPLETED",
                  "processingStatus": "PENDING",
                  "createdAt": "2026-06-20T10:15:00Z"
                }
              }
            }
          },
          "409": {
            "description": "La subida no se puede completar porque faltan partes o ya fue cancelada.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/uploads/{uploadId}/cancel": {
      "post": {
        "tags": ["uploads"],
        "summary": "Cancelar una subida en curso.",
        "description": "RF-P1: El sistema debe permitir cancelar una subida en curso.",
        "operationId": "cancelUpload",
        "parameters": [{ "$ref": "#/components/parameters/UploadIdParam" }],
        "responses": {
          "204": { "description": "Subida cancelada correctamente." },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/{assetId}/processing": {
      "get": {
        "tags": ["processing"],
        "summary": "Consultar estado de procesamiento.",
        "description": "RF-P2: El sistema debe exponer el estado del procesamiento (pendiente, en curso, completado, fallido).",
        "operationId": "getProcessingStatus",
        "parameters": [{ "$ref": "#/components/parameters/AssetIdParam" }],
        "responses": {
          "200": {
            "description": "Estado actual del procesamiento.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProcessingStatusResponse" },
                "example": {
                  "assetId": "ast-9d12ef",
                  "processingStatus": "IN_PROGRESS",
                  "jobs": [
                    { "jobId": "job-001", "targetQuality": "360p", "status": "COMPLETED" },
                    { "jobId": "job-002", "targetQuality": "720p", "status": "IN_PROGRESS" },
                    { "jobId": "job-003", "targetQuality": "1080p", "status": "PENDING" }
                  ]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/{assetId}/processing/retry": {
      "post": {
        "tags": ["processing"],
        "summary": "Reintentar un procesamiento fallido.",
        "description": "RF-P2: El sistema debe permitir reintentar un procesamiento fallido.",
        "operationId": "retryProcessing",
        "parameters": [{ "$ref": "#/components/parameters/AssetIdParam" }],
        "responses": {
          "202": {
            "description": "Reintento de procesamiento aceptado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProcessingStatusResponse" }
              }
            }
          },
          "409": {
            "description": "No se puede reintentar: el asset no esta en estado FAILED.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/assets/{assetId}/playback": {
      "get": {
        "tags": ["playback"],
        "summary": "Obtener informacion para reproducir un video.",
        "description": "RF-P3: El sistema debe permitir obtener la informacion necesaria para reproducir un video en un dispositivo dado, adaptando la entrega segun dispositivo, ancho de banda y region.",
        "operationId": "getPlaybackInfo",
        "parameters": [
          { "$ref": "#/components/parameters/AssetIdParam" },
          {
            "name": "device",
            "in": "query",
            "schema": { "type": "string", "enum": ["MOBILE", "DESKTOP", "TV", "WEB"] }
          },
          {
            "name": "region",
            "in": "query",
            "schema": { "type": "string", "example": "CL" }
          }
        ],
        "responses": {
          "200": {
            "description": "Datos de reproduccion adaptados.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlaybackInfo" },
                "example": {
                  "assetId": "ast-9d12ef",
                  "streamUrl": "https://cdn.youtube-ddd.local/ast-9d12ef/master.m3u8",
                  "availableQualities": ["360p", "720p", "1080p"],
                  "recommendedQuality": "720p"
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "423": {
            "description": "El asset existe pero el procesamiento aun no esta listo para reproducirse.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/playback-sessions": {
      "post": {
        "tags": ["playback"],
        "summary": "Iniciar una sesion de reproduccion.",
        "description": "RF-P3: El sistema debe registrar sesiones de reproduccion (inicio, progreso, finalizacion) y capturar metricas tecnicas.",
        "operationId": "startPlaybackSession",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePlaybackSessionRequest" },
              "example": { "assetId": "ast-9d12ef", "viewerId": "usr-44aa21", "device": "MOBILE" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sesion de reproduccion creada.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlaybackSession" },
                "example": {
                  "sessionId": "ses-3a5b9c",
                  "assetId": "ast-9d12ef",
                  "viewerId": "usr-44aa21",
                  "quality": "720p",
                  "startedAt": "2026-06-20T15:02:11Z",
                  "status": "ACTIVE"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/playback-sessions/{sessionId}/complete": {
      "post": {
        "tags": ["playback"],
        "summary": "Finalizar una sesion de reproduccion.",
        "description": "RF-P3: Captura metricas tecnicas finales: duracion vista, calidad utilizada, interrupciones. Emite el evento PlaybackSessionCompleted.",
        "operationId": "completePlaybackSession",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompletePlaybackSessionRequest" },
              "example": { "watchTimeSeconds": 245, "interruptions": 1, "finalQuality": "1080p" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sesion finalizada correctamente.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlaybackSession" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/live-streams": {
      "post": {
        "tags": ["live"],
        "summary": "Configurar una transmision en vivo.",
        "description": "RF-P4: El sistema debe permitir que un creador configure una transmision en vivo y proveer los datos de conexion (RTMP) para emitir desde OBS u otro software externo.",
        "operationId": "createLiveStream",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateLiveStreamRequest" },
              "example": { "creatorId": "usr-7f2a1c", "title": "Live de prueba tecnica" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transmision configurada con datos de conexion.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LiveStream" },
                "example": {
                  "liveId": "live-77cd02",
                  "creatorId": "usr-7f2a1c",
                  "status": "CONFIGURED",
                  "ingestUrl": "rtmp://ingest.youtube-ddd.local/live",
                  "streamKey": "sk_live_98f7e6d5"
                }
              }
            }
          }
        },
        "security": [{ "bearerAuth": ["creator"] }]
      }
    },
    "/live-streams/{liveId}/start": {
      "post": {
        "tags": ["live"],
        "summary": "Iniciar la transmision.",
        "description": "RF-P4: El sistema debe permitir iniciar una transmision previamente configurada.",
        "operationId": "startLiveStream",
        "parameters": [{ "name": "liveId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Transmision iniciada.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveStream" } } } },
          "409": { "description": "La transmision ya esta en curso o finalizada." }
        }
      }
    },
    "/live-streams/{liveId}/end": {
      "post": {
        "tags": ["live"],
        "summary": "Finalizar la transmision.",
        "description": "RF-P4: Al finalizar un live, el sistema debe poder generar una version grabada reutilizable como video on-demand (nuevo VideoAsset).",
        "operationId": "endLiveStream",
        "parameters": [{ "name": "liveId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": {
            "description": "Transmision finalizada. Se genera un VideoAsset grabado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LiveStream" },
                "example": {
                  "liveId": "live-77cd02",
                  "status": "ENDED",
                  "recordedAssetId": "ast-rec-44dd11"
                }
              }
            }
          }
        }
      }
    },
    "/creators/{creatorId}/assets": {
      "get": {
        "tags": ["assets"],
        "summary": "Listar assets tecnicos de un creador.",
        "description": "RF-P5: El sistema debe permitir listar los contenidos tecnicos asociados a un creador, con paginacion.",
        "operationId": "listCreatorAssets",
        "parameters": [
          { "name": "creatorId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/PageParam" },
          { "$ref": "#/components/parameters/PageSizeParam" }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de assets del creador.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AssetListResponse" }
              }
            }
          }
        }
      }
    },
    "/assets/{assetId}": {
      "get": {
        "tags": ["assets"],
        "summary": "Consultar el detalle tecnico de un asset.",
        "description": "RF-P5: El sistema debe permitir consultar el detalle tecnico de un asset (duracion, formatos disponibles, estado).",
        "operationId": "getAssetDetail",
        "parameters": [{ "$ref": "#/components/parameters/AssetIdParam" }],
        "responses": {
          "200": {
            "description": "Detalle tecnico del asset.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VideoAsset" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "AssetIdParam": {
        "name": "assetId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Identificador del VideoAsset (compartido como referencia con otros contextos, ver RNF-2)."
      },
      "UploadIdParam": {
        "name": "uploadId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "PageParam": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
      }
    },
    "schemas": {
      "InitiateUploadRequest": {
        "type": "object",
        "required": ["creatorId", "fileName", "fileSizeBytes"],
        "properties": {
          "creatorId": { "type": "string" },
          "fileName": { "type": "string" },
          "fileSizeBytes": { "type": "integer", "format": "int64" },
          "mode": { "type": "string", "enum": ["FULL", "MULTIPART"], "default": "FULL" }
        }
      },
      "UploadProgress": {
        "type": "object",
        "properties": {
          "uploadId": { "type": "string" },
          "partNumber": { "type": "integer" },
          "percentCompleted": { "type": "number", "format": "float" }
        }
      },
      "VideoAsset": {
        "type": "object",
        "description": "Aggregate Root de este Bounded Context. Representa el video como archivo tecnico, NUNCA como producto editorial.",
        "properties": {
          "assetId": { "type": "string" },
          "creatorId": { "type": "string" },
          "uploadStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "CANCELLED"] },
          "processingStatus": { "type": "string", "enum": ["NOT_STARTED", "PENDING", "IN_PROGRESS", "COMPLETED", "FAILED"] },
          "durationSeconds": { "type": "integer", "nullable": true },
          "availableQualities": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProcessingStatusResponse": {
        "type": "object",
        "properties": {
          "assetId": { "type": "string" },
          "processingStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "FAILED"] },
          "jobs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TranscodingJob" }
          }
        }
      },
      "TranscodingJob": {
        "type": "object",
        "description": "Entidad parte del agregado VideoAsset, relacion de composicion (no existe sin su asset).",
        "properties": {
          "jobId": { "type": "string" },
          "targetQuality": { "type": "string", "example": "720p" },
          "status": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "FAILED"] }
        }
      },
      "PlaybackInfo": {
        "type": "object",
        "properties": {
          "assetId": { "type": "string" },
          "streamUrl": { "type": "string", "format": "uri" },
          "availableQualities": { "type": "array", "items": { "type": "string" } },
          "recommendedQuality": { "type": "string" }
        }
      },
      "CreatePlaybackSessionRequest": {
        "type": "object",
        "required": ["assetId", "viewerId"],
        "properties": {
          "assetId": { "type": "string" },
          "viewerId": { "type": "string" },
          "device": { "type": "string", "enum": ["MOBILE", "DESKTOP", "TV", "WEB"] }
        }
      },
      "CompletePlaybackSessionRequest": {
        "type": "object",
        "properties": {
          "watchTimeSeconds": { "type": "integer" },
          "interruptions": { "type": "integer" },
          "finalQuality": { "type": "string" }
        }
      },
      "PlaybackSession": {
        "type": "object",
        "description": "Entidad del agregado VideoAsset. Cardinalidad 1 VideoAsset -- 0..* PlaybackSession.",
        "properties": {
          "sessionId": { "type": "string" },
          "assetId": { "type": "string" },
          "viewerId": { "type": "string" },
          "quality": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "COMPLETED"] },
          "startedAt": { "type": "string", "format": "date-time" },
          "watchTimeSeconds": { "type": "integer", "nullable": true }
        }
      },
      "CreateLiveStreamRequest": {
        "type": "object",
        "required": ["creatorId", "title"],
        "properties": {
          "creatorId": { "type": "string" },
          "title": { "type": "string" }
        }
      },
      "LiveStream": {
        "type": "object",
        "properties": {
          "liveId": { "type": "string" },
          "creatorId": { "type": "string" },
          "status": { "type": "string", "enum": ["CONFIGURED", "LIVE", "PAUSED", "ENDED"] },
          "ingestUrl": { "type": "string" },
          "streamKey": { "type": "string" },
          "recordedAssetId": { "type": "string", "nullable": true }
        }
      },
      "AssetListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/VideoAsset" } },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalItems": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "ASSET_NOT_READY" },
          "message": { "type": "string", "example": "El asset aun no completo su procesamiento." },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Solicitud invalida.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Unauthorized": {
        "description": "No autenticado.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotFound": {
        "description": "Recurso no encontrado.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token emitido por el sistema de identidad compartido (Google Account). El claim 'role' distingue creator/viewer/system."
      }
    }
  }
}
